# Operating-system and editor files
.DS_Store
**/.DS_Store
.idea/
.vscode/

# Python environments and caches
.venv/
**/.venv/
venv/
**/venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
**/.mypy_cache/
.ruff_cache/
**/.ruff_cache/

